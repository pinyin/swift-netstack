#!/bin/bash
# SwiftNetStack E2E init (Fedora/bootc initramfs edition).
#
# This is PID 1 when the image is used as an initramfs with the existing
# aarch64 kernel (Linux boot mode).  systemd is NOT started — we do
# everything manually.
#
# Runtime parameters (nat_target=, nat_tcp_port=, ...) arrive via
# /proc/cmdline, set by SwiftNetStackDemo --cmdline.

set -e

export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export HOME=/root

# ── Bootstrap ──────────────────────────────────────────────────────

mount -t proc     -o nosuid,noexec,nodev    proc     /proc
mount -t sysfs    -o nosuid,noexec,nodev    sysfs    /sys
mount -t devtmpfs -o mode=0755,nosuid       devtmpfs /dev
mkdir -p /dev/pts /dev/shm /run /tmp /etc
mount -t devpts   -o gid=5,mode=620,nosuid  devpts   /dev/pts
mount -t tmpfs    -o nosuid,nodev           tmpfs    /run
mount -t tmpfs    -o nosuid,nodev           tmpfs    /tmp
mount -t tmpfs    -o mode=0755,nosuid,nodev tmpfs    /etc

# Minimal /etc files (needed by dhclient, nslookup, etc.)
# NOTE: /etc was a tmpfs mount, so alternatives symlinks are lost.
# Restore critical ones that point through /etc/alternatives.
echo "root:x:0:" > /etc/group
echo "root:x:0:0:root:/root:/bin/bash" > /etc/passwd
echo "127.0.0.1 localhost" > /etc/hosts
ln -sf /usr/bin/ncat /usr/bin/nc  # alternatives symlink normally lives in /etc/alternatives

# ── Network ─────────────────────────────────────────────────────────

ip link set lo up 2>/dev/null || true
ip link set eth0 up 2>/dev/null || ifconfig eth0 up 2>/dev/null || true
[ -n "${MTU:-}" ] && ip link set eth0 mtu "$MTU" 2>/dev/null || true

# Custom minimal dhclient-script — skips ARP DAD which falsely triggers
# DHCPDECLINE on the BDP virtual network.
cat > /tmp/dhclient-script << 'DHCPSCRIPT'
#!/bin/bash
case "$reason" in
    BOUND|RENEW|REBIND|REBOOT)
        ip addr add "${new_ip_address}/${new_subnet_mask}" dev "${interface}" 2>/dev/null
        for router in ${new_routers}; do
            ip route add default via "$router" 2>/dev/null && break
        done
        [ -n "${new_domain_name_servers}" ] && echo "nameserver ${new_domain_name_servers}" > /etc/resolv.conf
        ;;
esac
DHCPSCRIPT
chmod +x /tmp/dhclient-script

echo "Requesting DHCP lease on eth0..."
dhclient -v -sf /tmp/dhclient-script eth0 2>&1 || true

# Wait for IP assignment
for i in $(seq 1 15); do
    if ip addr show eth0 2>/dev/null | grep -q 'inet '; then
        echo "eth0 IP: $(ip -4 addr show eth0 | grep inet | awk '{print $2}')"
        break
    fi
    sleep 2
done

echo "Routes:"
ip route show || true
echo "DNS:"
cat /etc/resolv.conf 2>/dev/null || true

# ── Run tests ───────────────────────────────────────────────────────

echo ""
echo "=== SwiftNetStack E2E Test Suite ==="
echo ""

TESTS_PASSED=""
TESTS_FAILED=""
TEST_COUNT=0
. /tests/lib.sh

TESTS="dhcp icmp arp dns routing nat-udp nat-udp-large nat-tcp nat-tcp-large nat-tcp-slow nat-tcp-rst nat-tcp-bidi nat-tcp-concurrent nat-tcp-concurrent-50 nat-tcp-stress nat-tcp-binary nat-tcp-large-multi-seg nat-iperf nat-internet nat-tcp-server-close nat-tcp-conn-refused nat-external-iperf nat-external-http chaos-tcp chaos-iperf"

for t in $TESTS; do
    TEST_SCRIPT="/tests/test-${t}.sh"
    if [ -f "$TEST_SCRIPT" ]; then
        set +e; . "$TEST_SCRIPT"; set -e
    else
        echo "[TEST] $t SKIP (not found)"
    fi
    echo ""
done

# Summary
. /tests/lib.sh
test_summary

echo ""
echo "=== Test suite complete, dropping to shell ==="
echo "(type poweroff -f to exit)"
exec /bin/bash
