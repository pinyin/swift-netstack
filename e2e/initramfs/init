#!/bin/sh
# SwiftNetStack E2E test suite entry point.
# Bootstraps the system, then runs each test in e2e/initramfs/tests/.

set -e

# ── Bootstrap ──────────────────────────────────────────────────────

mount -t proc     -o nosuid,noexec,nodev    proc     /proc
mount -t sysfs    -o nosuid,noexec,nodev    sysfs    /sys
mount -t devtmpfs -o mode=0755,nosuid       devtmpfs /dev
mkdir -p /dev/pts /dev/shm /run /tmp
mount -t devpts   -o gid=5,mode=620,nosuid  devpts   /dev/pts
mount -t tmpfs    -o nosuid,nodev           tmpfs    /run
mount -t tmpfs    -o nosuid,nodev           tmpfs    /tmp

# /etc on initramfs may be read-only; mount a writable tmpfs and restore essentials.
# Needed so udhcpc can write /etc/resolv.conf.
mount -t tmpfs -o mode=0755,nosuid,nodev tmpfs /etc
echo "root:x:0:" > /etc/group
echo "root:x:0:0:root:/root:/bin/sh" > /etc/passwd
echo "127.0.0.1 localhost" > /etc/hosts

echo "=== SwiftNetStack E2E Test Suite ==="
echo ""

ip link set lo up 2>/dev/null || true
ip link set eth0 up 2>/dev/null || ifconfig eth0 up 2>/dev/null || true
sleep 1

# Initialize shared test state (before sourcing any test scripts)
TESTS_PASSED=""
TESTS_FAILED=""
TEST_COUNT=0
. /tests/lib.sh

# ── Run tests in dependency order ──
#
# dhcp must run first (provides IP, gateway, DNS for other tests).
# icmp exercises L2+L3+L4 forwarding.
# arp validates proxy ARP response.
# dns validates hosts-file DNS resolution.
# routing validates default and subnet routes.

TESTS="dhcp icmp arp dns routing nat-udp nat-tcp nat-tcp-large nat-tcp-binary nat-tcp-concurrent nat-udp-large nat-internet nat-tcp-slow nat-tcp-server-close nat-tcp-concurrent-50 nat-tcp-bidi nat-tcp-large-multi-seg nat-tcp-conn-refused nat-tcp-rst"

for t in $TESTS; do
    TEST_SCRIPT="/tests/test-${t}.sh"
    if [ -f "$TEST_SCRIPT" ]; then
        set +e; . "$TEST_SCRIPT"; set -e
    else
        echo "[TEST] $t SKIP (not found)"
    fi
    echo ""
done

# ── Summary ──

. /tests/lib.sh
test_summary

echo ""
echo "=== Test suite complete, dropping to shell ==="
echo "(type poweroff -f to exit)"
exec /bin/sh
