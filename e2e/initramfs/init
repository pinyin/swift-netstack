#!/bin/sh
# E2E DHCP test init script for SwiftNetStack validation.
# Runs inside a minimal Linux VM with busybox.

set -e

# Mount essential filesystems
mount -t proc     -o nosuid,noexec,nodev    proc     /proc
mount -t sysfs    -o nosuid,noexec,nodev    sysfs    /sys
mount -t devtmpfs -o mode=0755,nosuid       devtmpfs /dev
mkdir -p /dev/pts /dev/shm /run /tmp
mount -t devpts   -o gid=5,mode=620,nosuid  devpts   /dev/pts
mount -t tmpfs    -o nosuid,nodev           tmpfs    /run
mount -t tmpfs    -o nosuid,nodev           tmpfs    /tmp

echo "=== SwiftNetStack DHCP E2E Test ==="
echo ""

# Bring up loopback
ip link set lo up 2>/dev/null || true

# Bring up eth0
echo "Bringing up eth0..."
ip link set eth0 up 2>/dev/null || ifconfig eth0 up 2>/dev/null || true
sleep 1

# Run DHCP client
echo "Running udhcpc on eth0..."
# -n: exit if lease not obtained
# -t 8: max 8 retries
# -T 2: 2 seconds between retries
udhcpc -i eth0 -n -t 8 -T 2 2>&1
UDHCPC_EXIT=$?

echo ""
echo "=== DHCP Result ==="
echo "udhcpc exit code: $UDHCPC_EXIT"
echo ""

echo "Interface eth0:"
ip addr show eth0 2>/dev/null || ifconfig eth0 2>/dev/null || true
echo ""

echo "Routing table:"
ip route show 2>/dev/null || route -n 2>/dev/null || true
echo ""

# Test connectivity to gateway
GATEWAY=$(ip route show 2>/dev/null | grep default | awk '{print $3}')
if [ -n "$GATEWAY" ]; then
    echo "Gateway: $GATEWAY"
    echo "Pinging gateway..."
    ping -c 3 -W 2 "$GATEWAY" 2>&1 || echo "Ping failed"
else
    echo "No default gateway found (DHCP may have failed)"
fi

echo ""
if [ "$UDHCPC_EXIT" -eq 0 ]; then
    echo "PASS: DHCP lease obtained"
else
    echo "FAIL: DHCP lease not obtained (udhcpc exit=$UDHCPC_EXIT)"
fi

echo ""
echo "=== Test complete, dropping to shell ==="
echo "(type poweroff -f to exit, or press Ctrl+C)"
exec /bin/sh
